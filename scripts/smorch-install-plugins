#!/usr/bin/env bash
set -euo pipefail

# smorch-install-plugins — Install plugins for your role
# GTM roles: Cowork only (no Code plugins)
# Dev/EO roles: Cowork + 7 Claude Code dev tools
# Works on: macOS, Linux

# --- Prerequisite checks ---
check_prereqs() {
    local missing=()
    command -v claude &>/dev/null || missing+=("claude")
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "\033[0;31mERROR: Missing required tools: ${missing[*]}\033[0m"
        echo "Install them before running this script."
        exit 1
    fi
}
check_prereqs

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

show_help() {
    echo "smorch-install-plugins — Install plugins for your role"
    echo ""
    echo "USAGE: smorch-install-plugins --role <role>"
    echo ""
    echo "ROLES:"
    echo "  --role gtm-eo       GTM-EO team (Cowork only, no Code plugins)"
    echo "  --role gtm-smo      GTM-SMO team (Cowork only, no Code plugins)"
    echo "  --role dev          Dev team (Cowork + 7 Code dev tools)"
    echo "  --role eo-student   EO student (Cowork + 7 Code dev tools)"
    echo "  --role mamoun       Everything"
    echo ""
    echo "  --list              Show what each role gets"
}

install_code_plugins() {
    echo -e "${CYAN}Installing 7 Claude Code Dev Tools${NC}"
    echo -e "${CYAN}(NOT available in Cowork — Code only)${NC}"
    echo ""
    echo -e "${BLUE}  Language Servers:${NC}"
    for p in typescript-lsp pyright-lsp rust-analyzer-lsp gopls-lsp; do
        echo -e "${BLUE}  Installing${NC} ${p}@claude-plugins-official..."
        if claude /plugin install "${p}@claude-plugins-official" 2>/dev/null; then
            echo -e "${GREEN}    OK${NC}"
        else
            echo -e "${YELLOW}    SKIP${NC} (already installed)"
        fi
    done
    echo ""
    echo -e "${BLUE}  Dev Tools:${NC}"
    for p in code-review frontend-design github; do
        echo -e "${BLUE}  Installing${NC} ${p}@claude-plugins-official..."
        if claude /plugin install "${p}@claude-plugins-official" 2>/dev/null; then
            echo -e "${GREEN}    OK${NC}"
        else
            echo -e "${YELLOW}    SKIP${NC} (already installed)"
        fi
    done
}

show_list() {
    echo -e "${CYAN}=== What Each Role Gets ===${NC}"
    echo ""
    echo -e "${GREEN}GTM-EO Team:${NC}"
    echo "  Cowork (7): smorch-context-brain, smorch-gtm-tools, smorch-gtm-engine,"
    echo "              smorch-design, mamoun-personal-branding, smorch-gtm-scoring,"
    echo "              eo-microsaas-os"
    echo "  Code:       None"
    echo "  Context:    EntrepreneurOasis"
    echo ""
    echo -e "${GREEN}GTM-SMO Team:${NC}"
    echo "  Cowork (6): smorch-context-brain, smorch-gtm-tools, smorch-gtm-engine,"
    echo "              smorch-design, mamoun-personal-branding, smorch-gtm-scoring"
    echo "  Code:       None"
    echo "  Context:    SalesMfastGTM + CC_CX"
    echo ""
    echo -e "${GREEN}Dev Team:${NC}"
    echo "  Cowork (2): smorch-dev, smorch-dev-scoring"
    echo "  Code (7):   typescript-lsp, pyright-lsp, rust-analyzer-lsp, gopls-lsp,"
    echo "              code-review, frontend-design, github"
    echo "  Context:    EntrepreneurOasis + SalesMfastGTM"
    echo ""
    echo -e "${GREEN}EO Student:${NC}"
    echo "  Cowork (3): eo-microsaas-os, smorch-dev, smorch-dev-scoring"
    echo "  Code (7):   typescript-lsp, pyright-lsp, rust-analyzer-lsp, gopls-lsp,"
    echo "              code-review, frontend-design, github"
    echo "  Context:    None"
}

MODE="${1:---help}"

case "$MODE" in
    --help|-h) show_help; exit 0 ;;
    --list) show_list; exit 0 ;;
    --role)
        ROLE="${2:-}"
        case "$ROLE" in
            gtm-eo)
                echo -e "${GREEN}=== GTM-EO Team Setup ===${NC}"
                echo ""
                echo -e "${YELLOW}No Claude Code plugins needed for GTM roles.${NC}"
                echo ""
                echo -e "${CYAN}Load plugins into Cowork Desktop:${NC}"
                echo "  1. Open Claude Desktop (Cowork)"
                echo "  2. Go to Customize > Workspace"
                echo "  3. Point workspace to your smorch-brain directory"
                echo "  4. Cowork scans and discovers all plugins automatically"
                echo "  5. Click Save -- plugins are now active"
                echo ""
                echo -e "${CYAN}Your role gets these 7 plugins:${NC}"
                echo "  - smorch-context-brain"
                echo "  - smorch-gtm-tools"
                echo "  - smorch-gtm-engine"
                echo "  - smorch-design"
                echo "  - mamoun-personal-branding"
                echo "  - smorch-gtm-scoring"
                echo "  - eo-microsaas-os"
                ;;
            gtm-smo)
                echo -e "${GREEN}=== GTM-SMO Team Setup ===${NC}"
                echo ""
                echo -e "${YELLOW}No Claude Code plugins needed for GTM roles.${NC}"
                echo ""
                echo -e "${CYAN}Load plugins into Cowork Desktop:${NC}"
                echo "  1. Open Claude Desktop (Cowork)"
                echo "  2. Go to Customize > Workspace"
                echo "  3. Point workspace to your smorch-brain directory"
                echo "  4. Cowork scans and discovers all plugins automatically"
                echo "  5. Click Save -- plugins are now active"
                echo ""
                echo -e "${CYAN}Your role gets these 6 plugins:${NC}"
                echo "  - smorch-context-brain"
                echo "  - smorch-gtm-tools"
                echo "  - smorch-gtm-engine"
                echo "  - smorch-design"
                echo "  - mamoun-personal-branding"
                echo "  - smorch-gtm-scoring"
                ;;
            dev)
                echo -e "${GREEN}=== Dev Team Setup ===${NC}"
                echo ""
                install_code_plugins
                echo ""
                echo -e "${CYAN}Load plugins into Cowork Desktop:${NC}"
                echo "  1. Open Claude Desktop (Cowork)"
                echo "  2. Go to Customize > Workspace"
                echo "  3. Point workspace to your smorch-brain directory"
                echo "  4. Cowork scans and discovers all plugins automatically"
                echo "  5. Click Save -- plugins are now active"
                echo ""
                echo -e "${CYAN}Your role gets these 2 plugins:${NC}"
                echo "  - smorch-dev"
                echo "  - smorch-dev-scoring"
                ;;
            eo-student)
                echo -e "${GREEN}=== EO Student Setup ===${NC}"
                echo ""
                install_code_plugins
                echo ""
                echo -e "${CYAN}Load plugins into Cowork Desktop:${NC}"
                echo "  1. Open Claude Desktop (Cowork)"
                echo "  2. Go to Customize > Workspace"
                echo "  3. Point workspace to your smorch-brain directory"
                echo "  4. Cowork scans and discovers all plugins automatically"
                echo "  5. Click Save -- plugins are now active"
                echo ""
                echo -e "${CYAN}Your role gets these 3 plugins:${NC}"
                echo "  - eo-microsaas-os"
                echo "  - smorch-dev"
                echo "  - smorch-dev-scoring"
                ;;
            mamoun)
                echo -e "${GREEN}=== Mamoun (All Access) ===${NC}"
                echo ""
                install_code_plugins
                echo ""
                echo -e "${CYAN}All Cowork plugins should already be installed.${NC}"
                ;;
            *)
                echo "Unknown role: $ROLE"
                echo "Available: gtm-eo, gtm-smo, dev, eo-student, mamoun"
                exit 1
                ;;
        esac
        ;;
    *) echo "Unknown: $MODE"; show_help; exit 1 ;;
esac

echo ""
echo -e "${GREEN}Done!${NC}"

#!/usr/bin/env bash
set -euo pipefail

# smorch (distribution) — SMOrchestra Skill Installer
# This is the team version. Source management commands are not available.

VERSION="2.0.0-dist"

if [[ -d "$HOME/Desktop/cowork-workspace/smorch-dist" ]]; then
    REPO_DIR="$HOME/Desktop/cowork-workspace/smorch-dist"
elif [[ -d "$HOME/smorch-dist" ]]; then
    REPO_DIR="$HOME/smorch-dist"
else
    REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi

SKILLS_TARGET="$HOME/.claude/skills"
STATE_FILE="$REPO_DIR/.smorch-state"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    cat <<EOF
smorch v${VERSION} — SMOrchestra Skill Installer (Team Edition)

Usage: smorch <command> [options]

Commands:
  pull --profile <name>   Install skills for your profile
  list                    Show available skills
  list --installed        Show installed skills
  list --profiles         Show available profiles
  status                  Profile, last sync, skill counts
  init --profile <name>   First-time setup

Registry: ${REPO_DIR}
Skills:   ${SKILLS_TARGET}
EOF
}

load_state() {
    CURRENT_PROFILE=""
    LAST_SYNC=""
    if [[ -f "$STATE_FILE" ]]; then
        source "$STATE_FILE"
    fi
}

save_state() {
    cat > "$STATE_FILE" <<EOF
CURRENT_PROFILE="${CURRENT_PROFILE}"
LAST_SYNC="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
EOF
}

cmd_pull() {
    load_state
    local profile="${CURRENT_PROFILE}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) profile="$2"; shift 2 ;;
            --force) shift ;;
            *) echo "Unknown: $1"; return 1 ;;
        esac
    done

    if [[ -z "$profile" ]]; then
        echo -e "${RED}ERROR: No profile set. Run: smorch pull --profile <name>${NC}"
        ls "$REPO_DIR/profiles/"*.txt 2>/dev/null | xargs -I{} basename {} .txt | sed 's/^/  /'
        return 1
    fi

    echo -e "${CYAN}smorch pull — Syncing profile: $profile${NC}"

    cd "$REPO_DIR"
    git pull --rebase origin main 2>&1 || true

    # Install team CLAUDE.md
    if [[ -f "$REPO_DIR/CLAUDE.md" ]]; then
        cp "$REPO_DIR/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
        echo -e "  ${GREEN}Installed team CLAUDE.md${NC}"
    fi

    # Verify hash integrity
    if [[ -f "$REPO_DIR/dist/.manifest" ]]; then
        echo -e "  Verifying plugin integrity..."
        local failures=0
        while IFS='  ' read -r expected_hash filename; do
            [[ -z "$expected_hash" ]] && continue
            local actual_hash=$(shasum -a 256 "$REPO_DIR/dist/$filename" 2>/dev/null | cut -d' ' -f1)
            if [[ "$expected_hash" != "$actual_hash" ]]; then
                echo -e "  ${RED}INTEGRITY FAILURE: $filename${NC}"
                failures=$((failures + 1))
            fi
        done < "$REPO_DIR/dist/.manifest"
        if [[ $failures -gt 0 ]]; then
            echo -e "${RED}$failures plugin(s) failed integrity check. Contact admin.${NC}"
            return 1
        fi
        echo -e "  ${GREEN}All plugins verified.${NC}"
    fi

    CURRENT_PROFILE="$profile"
    save_state
    echo -e "${GREEN}Profile '$profile' installed. Plugins available in $REPO_DIR/plugins/${NC}"
}

cmd_status() {
    load_state
    echo -e "${CYAN}smorch status (team edition)${NC}"
    echo "──────────────────────────────────"
    echo -e "Profile:    ${GREEN}${CURRENT_PROFILE:-<not set>}${NC}"
    echo -e "Last sync:  ${LAST_SYNC:-never}"
    echo -e "Registry:   $REPO_DIR"

    local plugin_count=$(ls "$REPO_DIR/dist/"*.plugin 2>/dev/null | wc -l | xargs)
    echo -e "Plugins:    ${GREEN}$plugin_count available${NC}"
    echo "──────────────────────────────────"
}

cmd_list() {
    local mode="registry"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --installed) mode="installed"; shift ;;
            --profiles) mode="profiles"; shift ;;
            *) shift ;;
        esac
    done

    case "$mode" in
        registry)
            echo -e "${CYAN}Available Plugins${NC}"
            for plugin in "$REPO_DIR/dist/"*.plugin; do
                [[ -f "$plugin" ]] || continue
                local name=$(basename "$plugin" .plugin)
                local size=$(du -h "$plugin" | cut -f1)
                echo -e "  ${GREEN}$name${NC} ($size)"
            done
            ;;
        profiles)
            echo -e "${CYAN}Available Profiles${NC}"
            for pf in "$REPO_DIR/profiles/"*.txt; do
                [[ -f "$pf" ]] || continue
                echo -e "  ${GREEN}$(basename "$pf" .txt)${NC}"
            done
            ;;
    esac
}

cmd_init() {
    local profile=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) profile="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [[ -z "$profile" ]]; then
        echo -e "${RED}Usage: smorch init --profile <name>${NC}"
        return 1
    fi

    echo -e "${CYAN}smorch init — Team setup${NC}"
    cmd_pull --profile "$profile"
    echo -e "${GREEN}Setup complete! Point Cowork Desktop to: $REPO_DIR/plugins/${NC}"
}

case "${1:-}" in
    pull)       shift; cmd_pull "$@" ;;
    list)       shift; cmd_list "$@" ;;
    status)     cmd_status ;;
    init)       shift; cmd_init "$@" ;;
    --version)  echo "smorch v${VERSION}" ;;
    push|build-plugin|audit|compile)
        echo -e "${RED}Command '$1' is not available in the team edition.${NC}"
        echo -e "Contact Mamoun for source-level operations."
        ;;
    -h|--help|"") usage ;;
    *)  echo -e "${RED}Unknown command: $1${NC}"; usage ;;
esac

#!/usr/bin/env bash
set -eo pipefail

# smorch-sync — Pull latest updates for all SMOrchestra repos
# Works on: macOS (bash 3.2+), Linux, Windows (Git Bash)
# Usage: smorch-sync [--help]

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

# Help
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "smorch-sync — Pull latest updates for all SMOrchestra repos"
    echo ""
    echo "Usage: smorch-sync [--help]"
    echo ""
    echo "Scans workspace for git repos and pulls latest from main (then dev)."
    echo "Override workspace path: export SMORCH_WORKSPACE=/your/path"
    exit 0
fi

# Prerequisite check
command -v git >/dev/null 2>&1 || {
    echo -e "${RED}[ERROR] git is required but not installed. See: https://git-scm.com/downloads${NC}"
    exit 1
}

# Auto-detect workspace directory (override with SMORCH_WORKSPACE env var)
if [[ -n "${SMORCH_WORKSPACE:-}" && -d "$SMORCH_WORKSPACE" ]]; then
    WORKSPACE="$SMORCH_WORKSPACE"
elif [[ -d "$HOME/Desktop/cowork-workspace" ]]; then
    WORKSPACE="$HOME/Desktop/cowork-workspace"
elif [[ -d "$HOME/smorch-workspace" ]]; then
    WORKSPACE="$HOME/smorch-workspace"
elif [[ -d "$HOME/workspace" ]]; then
    WORKSPACE="$HOME/workspace"
else
    echo -e "${RED}[ERROR] Cannot find workspace directory.${NC}"
    echo "Expected one of:"
    echo "  ~/Desktop/cowork-workspace/"
    echo "  ~/smorch-workspace/"
    echo "  ~/workspace/"
    echo "Or set: export SMORCH_WORKSPACE=/your/path"
    exit 1
fi

echo -e "${CYAN}smorch-sync — Pulling latest from all repos${NC}"
echo -e "Workspace: $WORKSPACE"
echo "──────────────────────────────────"

success=0
failed=0

for repo in "$WORKSPACE"/*/; do
    [[ -d "$repo/.git" ]] || continue
    name="$(basename "$repo")"

    # Try main first, then dev — capture error for diagnostics
    err_main=$(git -C "$repo" pull origin main 2>&1) && {
        echo -e "  ${GREEN}$name${NC} — synced (main)"
        success=$((success + 1))
        continue
    }
    err_dev=$(git -C "$repo" pull origin dev 2>&1) && {
        echo -e "  ${GREEN}$name${NC} — synced (dev)"
        success=$((success + 1))
        continue
    }
    # Both failed — show the error
    echo -e "  ${RED}$name${NC} — FAILED"
    echo -e "    ${YELLOW}$err_dev${NC}"
    failed=$((failed + 1))
done

echo "──────────────────────────────────"
echo -e "Synced: ${GREEN}$success${NC}  |  Failed: ${RED}$failed${NC}"

if [[ $failed -gt 0 ]]; then
    echo -e "${YELLOW}[WARN] Fix failed repos: cd into the repo and run 'git pull' to see full details.${NC}"
fi

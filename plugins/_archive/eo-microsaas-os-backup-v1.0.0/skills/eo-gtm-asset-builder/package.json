{
  "name": "eo-gtm-asset-builder",
  "version": "1.0.0",
  "description": "Production renderer: converts EO MENA GTM markdown blueprints into deployable HTML, PPTX, PDF, DOCX, XLSX files",
  "main": "render.js",
  "scripts": {
    "build": "node render.js --input ../../assets --brand ../../project-brain/brandvoice.md --output ./deployable",
    "build:clean": "rm -rf ./deployable/* && npm run build"
  },
  "dependencies": {
    "docx": "^9.1.0",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "pptxgenjs": "^3.12.0",
    "puppeteer": "^24.40.0"
  }
}
